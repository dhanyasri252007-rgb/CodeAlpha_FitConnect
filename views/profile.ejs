<%- include('partials/header') %>

<div class="profile-layout animate-fade-in">
  
  <!-- PROFILE SUMMARY COMPONENT -->
  <header class="card profile-header-card">
    <div class="profile-header-top">
      <div class="profile-avatar-large">
        <%= profileUser.username.substring(0, 1).toUpperCase() %>
      </div>
      
      <div class="profile-header-info">
        <div class="profile-username-row">
          <h1>@<%= profileUser.username %></h1>
          
          <!-- FOLLOW / EDIT PROFILE CALL TO ACTION -->
          <% if (profileUser._id === locals.user._id || profileUser._id.toString() === locals.user._id) { %>
            <button class="btn btn-navy-outline btn-sm animate-pulse-slow" id="openEditModalBtn" onclick="toggleEditProfileModal()">
              <i data-lucide="edit-3"></i> Edit Fitness Profile
            </button>
          <% } else { %>
            <% if (isFollowing) { %>
              <button class="btn btn-navy-outline btn-sm follow-action-btn followed" onclick="toggleProfileFollow('<%= profileUser._id %>')">
                <i data-lucide="user-check"></i> Connected (Unfollow)
              </button>
            <% } else { %>
              <button class="btn btn-primary btn-sm follow-action-btn" onclick="toggleProfileFollow('<%= profileUser._id %>')">
                <i data-lucide="user-plus"></i> Connect (Follow)
              </button>
            <% } %>
          <% } %>
        </div>

        <div class="profile-sub-row">
          <span class="badge badge-accent">
            <i data-lucide="target"></i> <%= profileUser.fitnessGoal %>
          </span>
          <span class="profile-join-date">
            <i data-lucide="calendar"></i> Joined FitConnect: <%= profileUser.createdAt.toLocaleDateString(undefined, { month: 'long', year: 'numeric' }) %>
          </span>
        </div>

        <p class="profile-full-bio">
          <%= profileUser.bio || 'This fitness lover hasn’t set up a bio yet.' %>
        </p>
      </div>
    </div>

    <!-- PROFILE STATISTICS COUNTERS -->
    <div class="profile-stats-grid">
      <div class="stat-box">
        <span class="stat-num"><%= postsCount %></span>
        <span class="stat-label"><i data-lucide="file-text"></i> Fitness Logs</span>
      </div>
      <div class="stat-box">
        <span class="stat-num" id="profileFollowerCount"><%= followerCount %></span>
        <span class="stat-label"><i data-lucide="users"></i> Goal Supporters</span>
      </div>
      <div class="stat-box">
        <span class="stat-num"><%= followingCount %></span>
        <span class="stat-label"><i data-lucide="award"></i> Peers Supported</span>
      </div>
    </div>
  </header>

  <!-- LIST OF USER HISTORY POSTS -->
  <div class="profile-posts-section">
    <div class="section-header">
      <h2><i data-lucide="history"></i> Log History</h2>
      <p>Workout milestones shared by @<%= profileUser.username %></p>
    </div>

    <div class="feed-posts">
      <% if (posts.length === 0) { %>
        <div class="card no-posts-card">
          <i data-lucide="dumbbell" class="no-posts-icon"></i>
          <h3>No Milestones Logged</h3>
          <p>No posts are displayed under this profile archive yet.</p>
        </div>
      <% } else { %>
        <% posts.forEach(post => { %>
          <article class="card post-article" data-post-id="<%= post._id %>">
            <header class="post-header">
              <div class="post-meta-left">
                <div class="avatar">
                  <%= profileUser.username.substring(0, 1).toUpperCase() %>
                </div>
                <div class="post-author-info">
                  <h4>@<%= profileUser.username %></h4>
                  <p class="post-author-goal"><i data-lucide="trophy" class="icon-inline"></i> <%= profileUser.fitnessGoal %></p>
                </div>
              </div>
              
              <div class="post-meta-right">
                <span class="post-time">
                  <i data-lucide="clock" class="icon-inline"></i> <%= post.createdAt.toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </span>
                
                <% if (profileUser._id === locals.user._id || profileUser._id.toString() === locals.user._id) { %>
                  <form action="/posts/<%= post._id %>/delete" method="POST" class="delete-post-form" onsubmit="return confirm('Do you want to delete this fitness log from your feed?');">
                    <button type="submit" class="btn-icon-trash" title="Delete Log">
                      <i data-lucide="trash-2"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </header>

            <div class="post-body">
              <p class="post-text"><%= post.content %></p>
              <% if (post.image) { %>
                <div class="post-image-container">
                  <img src="<%= post.image %>" alt="Milestone Photo" class="post-image" referrerPolicy="no-referrer">
                </div>
              <% } %>
            </div>

            <footer class="post-footer">
              <div class="post-stats-row">
                <button type="button" class="post-stat-btn like-btn <%= post.likes.includes(locals.user._id) ? 'liked' : '' %>" onclick="toggleLike('<%= post._id %>')">
                  <i data-lucide="heart"></i>
                  <span class="like-label">Like</span>
                  <span class="like-count"><%= post.likes.length %></span>
                </button>

                <button type="button" class="post-stat-btn comment-toggle-btn" onclick="toggleCommentsSection('<%= post._id %>')">
                  <i data-lucide="message-square"></i>
                  <span>Comments (<span class="comment-count"><%= post.comments.length %></span>)</span>
                </button>
              </div>

              <!-- COMMENTS SYSTEM -->
              <section class="post-comments-section" id="comments-<%= post._id %>" style="display: none;">
                <div class="comments-list" id="comments-list-<%= post._id %>">
                  <% if (post.comments.length === 0) { %>
                    <p class="no-comments-info">No commentaries on this workout log yet. Add structural feedback below!</p>
                  <% } else { %>
                    <% post.comments.forEach(comment => { %>
                      <div class="comment-item">
                        <div class="comment-avatar">
                          <%= comment.user.username.substring(0, 1).toUpperCase() %>
                        </div>
                        <div class="comment-bubble">
                          <div class="comment-top">
                            <span class="comment-author">@<%= comment.user.username %></span>
                            <span class="comment-time"><%= comment.createdAt.toLocaleDateString(undefined, {month:'short', day:'numeric'}) %></span>
                          </div>
                          <p class="comment-text"><%= comment.content %></p>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>

                <form action="/posts/<%= post._id %>/comment" method="POST" class="comment-form" onsubmit="submitCommentForm(event, '<%= post._id %>')">
                  <input type="text" name="content" class="comment-input" placeholder="Express feedback or post congrats..." required>
                  <button type="submit" class="btn btn-primary btn-xs">
                    <i data-lucide="corner-down-left"></i> Comment
                  </button>
                </form>
              </section>
            </footer>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>

</div>

<!-- EDIT HEALTH PROFILE POPUP DIALOG -->
<% if (profileUser._id === locals.user._id || profileUser._id.toString() === locals.user._id) { %>
  <div class="profile-modal-overlay" id="editProfileModal" style="display: none;">
    <div class="profile-modal card animate-scale-in">
      <div class="profile-modal-header">
        <h3><i data-lucide="edit-3" class="text-green"></i> Modify Fitness Target</h3>
        <button class="modal-close" onclick="toggleEditProfileModal()">&times;</button>
      </div>
      <div class="profile-modal-body">
        <form action="/profile/update" method="POST" class="auth-form">
          <div class="form-group">
            <label for="modalFitnessGoal"><i data-lucide="award"></i> Target Fitness Goal</label>
            <div class="select-wrapper">
              <select id="modalFitnessGoal" name="fitnessGoal">
                <option value="Fat Loss & Lean Muscle" <%= profileUser.fitnessGoal === 'Fat Loss & Lean Muscle' ? 'selected' : '' %>>🔥 Fat Loss & Lean Muscle</option>
                <option value="Powerlifting & Bulking" <%= profileUser.fitnessGoal === 'Powerlifting & Bulking' ? 'selected' : '' %>>💪 Powerlifting & Bulking</option>
                <option value="Marathon & Cardio Training" <%= profileUser.fitnessGoal === 'Marathon & Cardio Training' ? 'selected' : '' %>>🏃 Marathon & Cardio Training</option>
                <option value="Calisthenics & Mobility" <%= profileUser.fitnessGoal === 'Calisthenics & Mobility' ? 'selected' : '' %>>🧘 Calisthenics & Mobility</option>
                <option value="General Strength & Wellness" <%= profileUser.fitnessGoal === 'General Strength & Wellness' ? 'selected' : '' %>>⚡ General Strength & Wellness</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="modalBio"><i data-lucide="medal"></i> Fitness Bio / Journey</label>
            <textarea id="modalBio" name="bio" rows="4" placeholder="PRs, goals, injuries, routines..."><%= profileUser.bio %></textarea>
          </div>

          <div class="modal-buttons">
            <button type="button" class="btn btn-light" onclick="toggleEditProfileModal()">Cancel</button>
            <button type="submit" class="btn btn-primary"><i data-lucide="save"></i> Save Specifications</button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<%- include('partials/footer') %>
