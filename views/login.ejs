<%- include('partials/header') %>

<div class="auth-wrapper animate-fade-in">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-icon-circle">
        <i data-lucide="dumbbell"></i>
      </div>
      <h1>Log Back In</h1>
      <p>Securely enter your creds to join your workout peers.</p>
    </div>

    <!-- Alert triggers when error exists -->
    <% if (locals.error) { %>
      <div class="form-alert error">
        <i data-lucide="shield-alert"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/login" method="POST" class="auth-form" id="loginForm">
      <div class="form-group">
        <label for="email"><i data-lucide="mail"></i> Email Address</label>
        <input type="email" id="email" name="email" placeholder="coach@fitconnect.com" required autocomplete="email">
      </div>

      <div class="form-group">
        <label for="password"><i data-lucide="lock"></i> Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
      </div>

      <button type="submit" class="btn btn-primary btn-block">
        <i data-lucide="log-in"></i> Sign In to Feed
      </button>
    </form>

    <div class="auth-footer">
      <p>New to the fit crew? <a href="/register">Create an Account</a></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
